{
  "name": "panaderia-sistema",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"nodemon server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "node server/index.js",
    "db:schema": "node -e \"require('dotenv').config(); const {Pool}=require('pg'); const fs=require('fs'); const pool=new Pool({connectionString:process.env.DATABASE_URL,ssl:{rejectUnauthorized:false}}); pool.query(fs.readFileSync('./database/schema.sql','utf8')).then(()=>{console.log('Schema creado');pool.end()}).catch(e=>{console.error(e);pool.end()})\"",
    "db:seed": "node database/seed.js"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14",
    "vite": "^5.4.21"
  },
